+def _diff_check_safe_patch(text: str) -> str:
+    lines = []
+    for line in text.splitlines():
+        if line.startswith("+") and line.strip() == "+":
+            lines.append("+")
+        else:
+            lines.append(line)
+    return "\n".join(lines) + ("\n" if text.endswith("\n") else "")
