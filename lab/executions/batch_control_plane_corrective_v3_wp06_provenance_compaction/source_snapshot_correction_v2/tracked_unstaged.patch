+def _resolve_preimage_git_identity(repo_root: Path, rel_path: str, content_sha256: str) -> tuple[str, str]:
+    commits = _git_text(repo_root, "rev-list", "--all", "--", rel_path).splitlines()
+    for commit in commits:
